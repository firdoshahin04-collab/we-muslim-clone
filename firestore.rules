rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "firdoshahin04@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidString(val, min, max) {
      return val is string && val.size() >= min && val.size() <= max;
    }

    function isRecent(ts) {
      return ts is timestamp && ts <= request.time && ts > request.time - duration.value(5, 'm');
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'karmaPoints', 'level']) &&
             data.uid == request.auth.uid &&
             data.karmaPoints is number &&
             data.level is number;
    }

    function isValidDua(data) {
      return data.keys().hasAll(['content', 'authorUid', 'ameenCount', 'createdAt']) &&
             isValidString(data.content, 1, 1000) &&
             data.authorUid == request.auth.uid &&
             data.ameenCount is number &&
             data.ameenCount >= 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // User Profile Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                      request.resource.data.karmaPoints >= resource.data.karmaPoints;
      
      match /checkins/{date} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && 
                                request.resource.data.count <= 5 &&
                                request.resource.data.count >= 0;
      }
    }

    // Dua Wall Rules
    match /duas/{duaId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidDua(request.resource.data);
      allow update: if isAuthenticated() && (
        // Allow anyone to increment ameenCount
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ameenCount']) &&
         request.resource.data.ameenCount == resource.data.ameenCount + 1) ||
        // Allow owner to edit content
        (isOwner(resource.data.authorUid) && isValidDua(request.resource.data))
      );

      match /replies/{replyId} {
        allow read: if true;
        allow create: if isAuthenticated() && 
          request.resource.data.authorUid == request.auth.uid &&
          isValidString(request.resource.data.content, 1, 500);
      }
    }

    // Challenges (Publicly readable, Admin writable)
    match /challenges/{challengeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Quotes (Publicly readable, Admin writable)
    match /quotes/{quoteId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
